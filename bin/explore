#!/usr/bin/env ruby
# frozen_string_literal: true

# Runs a single exploration pipeline iteration locally without Sidekiq/Redis.
#
# Usage:
#   bin/explore                  # runs all services from config
#   bin/explore aws/s3           # runs a single service by key

require "bundler/setup"
require_relative "../lib/barista"

service_key = ARGV.first

if service_key
  parsed = Barista::Providers::Service.parse_key(service_key)
  provider = Barista.configuration.providers.find { |p| p.name == parsed[:provider_name] }
  service = provider&.services&.find { |s| s.name == parsed[:service_name] }

  abort "Unknown service key: #{service_key}" unless service

  puts "Fetching #{service.url}..."
  content = Barista::Fetcher.fetch(service.url)

  puts "Synthesizing (#{content.length} bytes)..."
  intermediate = Barista::Synthesizer.synthesize(service:, content:)

  puts "Found #{intermediate.guarantees.size} guarantee(s)"
  caffeine = Barista::Translator.translate(intermediate)

  path = Barista::CaffeineWriter.write(service:, content: caffeine)
  puts "Wrote #{path}"
  puts
  puts caffeine
else
  keys = Barista.configuration.providers.flat_map { |p| p.services.map(&:key) }
  abort "No services found in config" if keys.empty?

  keys.each do |key|
    puts "--- #{key} ---"
    system(__FILE__, key) || abort("Failed on #{key}")
    puts
  end
end
